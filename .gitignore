# ─── VS Code: commit shared workspace config, ignore everything else ─
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ─── Glifex compiled harness artifacts ──────────────────────────────
.glifex_bin
.glifex.jar

# ─── Playground vendored WASM runtimes (fetched, never committed) ───
web/vendor/
test-results/
node_modules/
glifex_bin.exe
web/version.json
.glifex.wasm

# .NET build outputs — machine-specific, never commit
bin/
obj/
# .NET file-based-app run cache — contains absolute Codespace paths
dotnet/runfile-discovery/
*Zone.Identifier
