# Pinned inputs for the arm64 toolchain (Bx-10). See docs/vixl-arm64.md.
#
# THIS FILE IS THE CACHE KEY. pages.yml/ci.yml hash tools/arm64-toolchain/**,
# so editing any pin here invalidates the vendor cache and forces a rebuild;
# leave it alone and the cache hits and the build is skipped. One place to bump.

# The AArch64 Simulator. gitlab.arm.com is CANONICAL -- github.com/Linaro/vixl
# is a stale mirror, frozen at the repo migration commit (2026-04-17).
VIXL_COMMIT=d61a1e74fcc15c86059e326f4326c825fb6b4635

# Guest assembler + linker. Built musl-static, x86-64 host, aarch64 target.
BINUTILS_VERSION=2.43
# Integrity, not reproducibility -- BINUTILS_VERSION above already pins WHICH
# tarball. Without this we trust ftp.gnu.org to serve the right bytes, and a
# swapped tarball would build silently. Printed by the build itself, twice, before
# being pasted here; it was left blank until we had actually seen it.
BINUTILS_SHA256=b53606f443ac8f01d1d5fc9c39497f2af322d99e14cea5c0b4b124d630379365

# The Blink build production already ships (pages.yml vendors this exact ref).
BLINKENLIB_REF=d617f6a19879157c1debbe0454b6c4cff2ebe094
BLINKENLIB_JS_SHA256=687b3d3cb033175d245c324c394d4587d9f459fb4f732eb2b340c097a8619063
BLINKENLIB_WASM_SHA256=dd409970974929ab04d6b45978df01140d63ad2054ba7a550b6259e0a07f476a

# The emscripten SDK that compiles VIXL to wasm. "latest" meant two builds a
# month apart could use different compilers and emit different wasm -- and it is
# the prime suspect for the unexplained gx_init swing (103 ms on a spike build,
# 267 ms on the deployed one, same source).
#
# 6.0.3 is what "latest" resolved to, and it is a real installable version string
# (emsdk list confirms it), not a guess. The build still records the resolved
# emcc version in the manifest.
EMSDK_VERSION=6.0.3
