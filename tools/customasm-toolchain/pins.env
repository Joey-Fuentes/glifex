# customasm-toolchain/pins.env
# customasm -- the assembler behind the asm-6502 retro track -- built to
# WebAssembly from pinned source at deploy, like teavm-javac and dart2js, NOT
# fetched as an opaque blob.
#
# WHY BUILT, NOT FETCHED. customasm's browser wasm exists ONLY as the artifact of
# a throwaway 'ghpages' branch: upstream's .github/workflows/build_ghpages.yml runs
#   cargo build --lib --target wasm32-unknown-unknown --release
# moves target/.../release/customasm.wasm to web/customasm.wasm, and force-pushes
# it to ghpages. It is never on main, never a git tag, and NOT a release asset (the
# releases carry only the native CLI zips). So there is no fetchable, pinnable URL
# -- the live demo page was a moving single point of failure. We build the SAME way
# upstream does, from the pinned commit below.
#
# The tag is a convenience; the COMMIT is the pin (a tag can move, a commit cannot).
CUSTOMASM_REPO=https://github.com/hlorenzi/customasm
CUSTOMASM_TAG=v0.14.1
CUSTOMASM_COMMIT=c66cb389e7af95ad612520d4766bcb09adfea948
# Upstream floats 'stable'; we pin so the build is reproducible. If cargo reports
# an MSRV/edition error, bump this deliberately (it is the one value most likely to
# need adjusting for a future customasm).
CUSTOMASM_RUST_VERSION=1.86.0
