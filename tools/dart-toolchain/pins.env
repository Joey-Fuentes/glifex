# Pinned inputs for the Dart browser toolchain (Bx-13). See docs/dart2js-self-hosted.md.
#
# THIS FILE IS PART OF THE CACHE KEY. pages.yml/ci.yml hash tools/**, so editing
# any pin here invalidates the vendor cache and forces a rebuild. One place to
# bump, no manual key juggling.

# The SDK. Both numbers are the SAME STRING on purpose: DART_SDK_VERSION is what
# setup-dart installs, DART_SDK_TAG is what we clone the sources from. They MUST
# agree -- compiling main's sources with a stable compiler is what sank spikes 3
# and 4, with a "testing requires SDK ^3.13.0-0" that looked like a Dart problem
# and was ours.
#
# NOT "stable". The spike used sdk: stable and derived the tag from whatever it
# resolved to -- self-consistent, but a pins.env that says "stable" is a cache
# key that never changes while the artifact underneath it does. That is the
# never-stale property broken silently, and it is the same lesson EMSDK_VERSION
# learned in riscv-toolchain/pins.env: "latest" meant two builds a month apart
# could use different compilers.
#
# 3.12.2 was the latest stable when this track was proven (released 2026-06-09;
# setup-dart resolved 'stable' to it on 2026-07-17). Dart ships stable roughly
# quarterly. Bumping is one line here; the four patch
# anchors below are verified byte-exact at 3.12.2 AND at main (3.14.0-edge), so
# a bump is very unlikely to need new anchors -- but re-run the verify, which
# compiles a kata rather than checking a file exists.
DART_SDK_VERSION=3.12.2
DART_SDK_TAG=3.12.2

# THE PATCH. pkg/kernel/lib/binary/ast_from_binary.dart keys its Name cache as
#     stringReference | ((libraryReferenceIndex) << 30)
# Both bitwise operators are 32-BIT ON WEB TARGETS, so the key retains only
# libraryReferenceIndex & 3: two libraries congruent mod 4 collide and the cache
# returns whichever Name was read first. dart2js is faithful -- it compiled a
# 64-bit assumption to correct 32-bit web semantics. The defect is kernel's,
# latent since e3d4fbec80c (2022, "[kernel] Deduplicate Names when loading dill").
#
# Without it, a dart2js compiled by dart2js cannot compile anything at all.
# There is no pin here because the patch is pinned BY DART_SDK_TAG: the anchors
# are asserted unique at build time and the build refuses if any drifts.
# Reported upstream against pkg/kernel; drop this when the CL lands (see
# docs/UPSTREAM-NOTES.md items 4-7).
DART_KERNEL_PATCH=ast_from_binary-name-cache-record-key

# What a browser fetches, for reference -- measured, not budgeted:
#   gx_web.js              ~16.2 MB raw / ~2.37 MB gz   (the compiler, as JS)
#   dart2js_platform.dill  ~10.3 MB raw / ~3.28 MB gz   (the platform, as bytes)
#   libraries.json           ~22 KB raw /   ~2 KB gz
# ~5.7 MB gzipped total -- below php (10M) and python (12M), and less than half
# of dart-live's whole-VM route (36.5 / 11.2).
