# Pinned inputs for the riscv64 toolchain (Bx-10b). See docs/libriscv-riscv64.md.
#
# THIS FILE IS PART OF THE CACHE KEY. pages.yml/ci.yml hash tools/**, so editing
# any pin here invalidates the vendor cache and forces a rebuild. One place to
# bump, no manual key juggling.

# The emulator. BSD-3-Clause, built for embedding, and it already had a wasm
# example in-tree -- which is why this track started from a working build where
# Bx-10 started from "nobody has ever built VIXL to wasm".
LIBRISCV_COMMIT=2a501bab10dca3b99370300049bd39d1098e8cd0

# Guest assembler + linker. Built musl-static, x86-64 host, riscv64 target --
# Bx-10's recipe with one triple changed. 1.94 MB, smaller than arm64's 2.85 MB.
BINUTILS_VERSION=2.43
# Integrity, not reproducibility -- BINUTILS_VERSION above already pins WHICH
# tarball. Without this we trust ftp.gnu.org to serve the right bytes. Printed by
# the build itself before being pasted here.
BINUTILS_SHA256=b53606f443ac8f01d1d5fc9c39497f2af322d99e14cea5c0b4b124d630379365

# The Blink build production already ships. Vendored a THIRD time here (~250 KB);
# sharing one copy across asm-x86_64/asm-arm64/asm-riscv64 is an open item in
# docs/libriscv-riscv64.md section 6, not a default.
BLINKENLIB_REF=d617f6a19879157c1debbe0454b6c4cff2ebe094
BLINKENLIB_JS_SHA256=687b3d3cb033175d245c324c394d4587d9f459fb4f732eb2b340c097a8619063
BLINKENLIB_WASM_SHA256=dd409970974929ab04d6b45978df01140d63ad2054ba7a550b6259e0a07f476a

# The emscripten SDK that compiles libriscv to wasm. "latest" meant two builds a
# month apart could use different compilers and emit different wasm. 6.0.3 is what
# "latest" resolved to and is a real installable version string (emsdk list
# confirms it), not a guess. The build still records the resolved emcc version in
# the manifest.
EMSDK_VERSION=6.0.3
