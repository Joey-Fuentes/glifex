# Pinned inputs for the Zig browser toolchain (Bx-11). See docs/zig-self-hosted.md.
#
# THIS FILE IS THE CACHE KEY. ci.yml/pages.yml hash tools/**, so editing any pin
# here invalidates the vendor cache and forces a rebuild; leave it alone and the
# cache hits and the build is skipped. One place to bump.
#
# THE FINDING, in one line: a Zig compiler that is itself wasm32-wasi compiles
# Zig to native wasm in the browser, from pinned upstream 0.16.0 + one 8-line
# patch. No fork, no nightly, no LLVM in the artifact. The full trail -- and the
# ten rounds of self-inflicted dead ends -- is in docs/zig-self-hosted.md.

# The HOST zig that BUILDS zig.wasm. A real release from ziglang.org (index.json),
# NOT mlugg/setup-zig -- setup-zig@v1 asked the nightly path for a release name and
# 404'd every mirror. index.json is the source of truth for the URL and the shasum.
ZIG_HOST_VERSION=0.16.0
# sha256 of zig-x86_64-linux-0.16.0.tar.xz from ziglang.org/download/index.json.
# Left blank until the build has PRINTED it once (same discipline as binutils):
# integrity, not reproducibility -- ZIG_HOST_VERSION already pins which tarball.
ZIG_HOST_SHA256=

# The SOURCE that becomes zig.wasm: the SAME 0.16.0 release, its src tarball.
# The browser compiler and the CLI both speak this exact std -- the Bx invariant.
ZIG_SRC_VERSION=0.16.0
ZIG_SRC_SHA256=

# The one patch. This IS the zigtools/zig wasm32-wasi fork's entire delta over
# Release 0.16.0: commit 1c430bc13, "make it possible compile to wasm32-wasi with
# -Ddev=wasm", 8 lines against src/dev.zig and nothing else. Vendored as
# tools/zig-toolchain/dev-wasm.patch, lifted from the fork's own git history --
# NOT from zigtools/playground, whose published zig.patch is stale (missing
# .legalize, cut when .wasm was the last enum arm) and could never apply.
# Verified byte-for-byte against the 0.16.0 tarball offline before shipping.
ZIG_PATCH=dev-wasm.patch

# The build flags, recorded so the recipe is legible without reading build script.
# NOTE the absence of -Duse-llvm=false. That flag is what made rounds 1-4 SIGSEGV:
# it forces the HOST onto zig's self-hosted wasm backend (a real bug). The host is
# a build machine; let it use LLVM. -Ddev=wasm is what keeps LLVM out of the
# ARTIFACT. -Dno-lib keeps lib/ out of the compiler; we ship lib/std separately.
ZIG_BUILD_FLAGS=-Dtarget=wasm32-wasi -Doptimize=ReleaseSmall -Dno-lib=true -Ddev=wasm
